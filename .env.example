# Arr API keys
export RADARR_KEY=your_radarr_api_key
export SONARR_KEY=your_sonarr_api_key

# Bazarr
export BAZARR_API_KEY=your_bazarr_api_key

# Transmission
export TRANSMISSION_URL=https://your-transmission-host/transmission/rpc
export TRANSMISSION_USER=your_user
export TRANSMISSION_PASS=your_pass

# Emby
export EMBY_URL=https://your-emby-host
export EMBY_API_KEY=your_emby_api_key

# Discord webhook (single channel for all notifications)
export DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_discord_webhook

# Translation provider monthly character budgets (default values shown)
# DeepL free tier = 500k/mo; budget set lower to leave headroom
export GEMINI_MONTHLY_BUDGET=500000
export GOOGLE_MONTHLY_BUDGET=500000

# Gemini daily request budget (file-level rows, not raw API batch calls).
# gemini-2.5-pro free tier: ~50 RPD per project; each file ≈ 5 batch calls,
# so 50/5 = 10 files/day max. Default 9 = 10% safety margin below that ceiling.
# With multiple Gemini keys: RPD is per-project (not per-key), so keys do NOT
# multiply the daily cap. Increase only if you have a paid tier or confirmed
# higher limits in AI Studio (https://aistudio.google.com/rate-limit).
export GEMINI_DAILY_REQUESTS_BUDGET=9

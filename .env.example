# Arr API keys
export RADARR_KEY=your_radarr_api_key
export SONARR_KEY=your_sonarr_api_key

# Bazarr
export BAZARR_API_KEY=your_bazarr_api_key

# Transmission
export TRANSMISSION_URL=https://your-transmission-host/transmission/rpc
export TRANSMISSION_USER=your_user
export TRANSMISSION_PASS=your_pass

# Emby
export EMBY_URL=https://your-emby-host
export EMBY_API_KEY=your_emby_api_key

# Discord webhook (single channel for all notifications)
export DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_discord_webhook

# Translation provider budgets — per individual API key (default values shown).
# DeepL free tier: 500k chars/mo per key.
# Gemini 2.5 Pro free tier: 500k chars/mo and ~50 RPD per project per key.
export DEEPL_MONTHLY_BUDGET_PER_KEY=500000
export GEMINI_MONTHLY_BUDGET_PER_KEY=500000
export GEMINI_DAILY_REQUESTS_BUDGET_PER_KEY=9
# Aggregate Google budget (no per-key tracking — no authenticated free tier).
export GOOGLE_MONTHLY_BUDGET=500000

# Backward compat: old names (without _PER_KEY suffix) are still honored with
# a deprecation log line. Rename to the _PER_KEY forms above at your convenience.
# export GEMINI_MONTHLY_BUDGET=500000
# export GEMINI_DAILY_REQUESTS_BUDGET=9

# Pipeline budget / rate-limit (added 2026-04-29)
export TRANSLATOR_MAX_FILES_PER_RUN=3
export TRANSLATOR_SINCE_MINUTES=10
export OLLAMA_MAX_WORKERS=2
export TIMEOUT_TRANSLATION=600

# Service URLs (centralized 2026-04-29)
export BAZARR_URL=http://127.0.0.1:6767/bazarr
export BAZARR_DB=/opt/bazarr/data/db/bazarr.db
export RADARR_URL=http://127.0.0.1:7878/radarr
export SONARR_URL=http://127.0.0.1:8989/sonarr
export DEBIAN_OLLAMA_URL=http://172.20.77.2:11434
